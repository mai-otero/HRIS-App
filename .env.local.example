# Supabase
# Find these in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role key — NEVER expose this to the browser.
# Used in server-side API routes for admin operations (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend (email notifications) — Step 8
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here

# Admin email addresses (comma-separated)
# Used to send PTO notification emails
ADMIN_EMAIL_1=admin1@yourcompany.com
ADMIN_EMAIL_2=admin2@yourcompany.com

# From address for outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourcompany.com
